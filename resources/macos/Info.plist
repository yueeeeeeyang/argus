<?xml version="1.0" encoding="UTF-8"?>
<!--
  文件职责：macOS Argus.app 打包用 Info.plist 模板。
  创建日期：2026-06-15
  修改日期：2026-07-07
  作者：Argus 开发团队
  主要功能：声明应用基础信息、URL 打开能力和 Finder Open With 可识别的文档类型。
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>zh_CN</string>
	<key>CFBundleDisplayName</key>
	<string>Argus</string>
	<key>CFBundleExecutable</key>
	<string>argus</string>
	<key>CFBundleIdentifier</key>
	<string>com.yueyang.argus</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Argus</string>
	<key>CFBundleIconFile</key>
	<string>AppIcon</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.1.0</string>
	<key>CFBundleVersion</key>
	<string>0.1.0</string>
	<key>LSMinimumSystemVersion</key>
	<string>12.0</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>Argus External Open</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>argus</string>
			</array>
		</dict>
	</array>
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Argus Supported Sources</string>
			<key>CFBundleTypeRole</key>
			<string>Viewer</string>
			<key>LSHandlerRank</key>
			<string>Alternate</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>public.data</string>
				<string>public.folder</string>
				<string>public.archive</string>
				<string>com.pkware.zip-archive</string>
				<string>org.gnu.gnu-zip-archive</string>
				<string>public.tar-archive</string>
				<string>public.bzip2-archive</string>
				<string>org.tukaani.xz-archive</string>
				<string>org.7-zip.7-zip-archive</string>
				<string>com.rarlab.rar-archive</string>
				<!-- .log 文件的具体 UTI 为 com.apple.log（conforms to public.log/public.plain-text）。
				     public.data 虽是基类但过于抽象，LaunchServices 不会据此把 Argus 列入 .log 的“打开方式”，
				     故需显式声明具体 UTI，否则右键无法用 Argus 打开 .log。 -->
				<string>com.apple.log</string>
				<string>public.log</string>
				<string>public.plain-text</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
